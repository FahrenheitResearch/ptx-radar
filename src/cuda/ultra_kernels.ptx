//
// ultra_kernels.ptx -- Hand-written PTX kernels for cursdar3.
//
// These replace nvcc-compiled CUDA C kernels with hand-tuned PTX. Loaded at
// runtime via the CUDA Driver API (cuModuleLoadData / cuModuleGetFunction)
// and launched via cuLaunchKernel from src/cuda/renderer.cu. The driver JITs
// this PTX to native SASS for whatever Blackwell / Ada / Ampere arch is
// present, so we don't need separate per-arch builds.
//
// Naming convention: every entry is prefixed `ultra_` so symbols can never
// collide with the nvcc-compiled symbols of the same logical kernel.
//
// Author: hand-written -- not generated from CUDA C.
//
.version 9.0
.target sm_86
.address_size 64

//==============================================================
// Dynamic shared memory used by ultra_singleStationKernel for the
// cooperative azimuth-array load (size set by the launch's smem bytes).
//==============================================================
.extern .shared .align 16 .b8 ultra_s_az[];

//==============================================================
// ultra_clearKernel
//
//   void clearKernel(uint32_t* buf, int width, int height, uint32_t color)
//
//   Per-pixel writes `color` to buf[py*width + px]. Trivial, but proves the
//   PTX loader / launcher path end-to-end.
//==============================================================
.visible .entry ultra_clearKernel(
    .param .u64 ck_buf,
    .param .u32 ck_w,
    .param .u32 ck_h,
    .param .u32 ck_c
)
{
    .reg .pred  %p<4>;
    .reg .u32   %r<16>;
    .reg .u64   %rd<6>;

    // px = blockIdx.x * blockDim.x + threadIdx.x
    mov.u32     %r1, %ctaid.x;
    mov.u32     %r2, %ntid.x;
    mov.u32     %r3, %tid.x;
    mad.lo.u32  %r4, %r1, %r2, %r3;

    // py = blockIdx.y * blockDim.y + threadIdx.y
    mov.u32     %r5, %ctaid.y;
    mov.u32     %r6, %ntid.y;
    mov.u32     %r7, %tid.y;
    mad.lo.u32  %r8, %r5, %r6, %r7;

    // Bounds check
    ld.param.u32 %r9,  [ck_w];
    ld.param.u32 %r10, [ck_h];
    setp.ge.u32  %p1, %r4, %r9;
    setp.ge.u32  %p2, %r8, %r10;
    or.pred      %p1, %p1, %p2;
    @%p1 bra     L_CK_END;

    // idx = py * width + px ; byte offset = idx * 4
    mad.lo.u32   %r11, %r8, %r9, %r4;
    mul.wide.u32 %rd1, %r11, 4;
    ld.param.u64 %rd2, [ck_buf];
    add.s64      %rd3, %rd2, %rd1;

    ld.param.u32 %r12, [ck_c];
    st.global.u32 [%rd3], %r12;

L_CK_END:
    ret;
}

//==============================================================
// ultra_clearKernel_v4
//
//   void clearKernel_v4(uint32_t* buf, int width, int height, uint32_t color)
//
//   Vectorized variant: each thread writes FOUR adjacent pixels via a
//   single 16-byte st.global.v4.b32. 4x fewer threads, 4x larger stores,
//   higher memory-pipeline utilization. Falls back to scalar stores for
//   the partial bundle at the right edge when width is not a multiple of 4.
//
//   Launch with: gx = (width + 4*bx - 1) / (4*bx); same gy as the scalar
//   version. The kernel multiplies the thread index by 4 internally.
//==============================================================
.visible .entry ultra_clearKernel_v4(
    .param .u64 ck4_buf,
    .param .u32 ck4_w,
    .param .u32 ck4_h,
    .param .u32 ck4_c
)
{
    .reg .pred  %p<6>;
    .reg .u32   %r<24>;
    .reg .u64   %rd<8>;

    // Bundle x = blockIdx.x * blockDim.x + threadIdx.x
    mov.u32     %r1, %ctaid.x;
    mov.u32     %r2, %ntid.x;
    mov.u32     %r3, %tid.x;
    mad.lo.u32  %r4, %r1, %r2, %r3;
    shl.b32     %r5, %r4, 2;            // px = bundle * 4

    mov.u32     %r6, %ctaid.y;
    mov.u32     %r7, %ntid.y;
    mov.u32     %r8, %tid.y;
    mad.lo.u32  %r9, %r6, %r7, %r8;     // py

    ld.param.u32 %r10, [ck4_w];
    ld.param.u32 %r11, [ck4_h];
    setp.ge.u32  %p1, %r5, %r10;
    setp.ge.u32  %p2, %r9, %r11;
    or.pred      %p1, %p1, %p2;
    @%p1 bra     L_CK4_END;

    // Compute base byte address: (py * w + px) * 4
    mad.lo.u32   %r12, %r9, %r10, %r5;
    mul.wide.u32 %rd1, %r12, 4;
    ld.param.u64 %rd2, [ck4_buf];
    add.s64      %rd3, %rd2, %rd1;
    ld.param.u32 %r13, [ck4_c];

    // Fast path: all 4 pixels in bounds (most common -- only the right
    // edge falls into the partial path).
    add.u32      %r14, %r5, 3;
    setp.lt.u32  %p3, %r14, %r10;
    @!%p3 bra    L_CK4_PARTIAL;

    st.global.v4.b32 [%rd3], {%r13, %r13, %r13, %r13};
    bra          L_CK4_END;

L_CK4_PARTIAL:
    // Write 1-3 pixels with scalar stores, checking each.
    st.global.u32 [%rd3], %r13;
    add.u32      %r5, %r5, 1;
    setp.ge.u32  %p4, %r5, %r10;
    @%p4 bra     L_CK4_END;
    st.global.u32 [%rd3+4], %r13;
    add.u32      %r5, %r5, 1;
    setp.ge.u32  %p4, %r5, %r10;
    @%p4 bra     L_CK4_END;
    st.global.u32 [%rd3+8], %r13;

L_CK4_END:
    ret;
}

//==============================================================
// ultra_forwardResolveKernel
//
//   void forwardResolveKernel(const uint64_t* accum, int width, int height,
//                             uint32_t* output, uint32_t background)
//
//   The forward rasterizer accumulates `(range_key << 32) | rgba` into a
//   uint64 per pixel, with the sentinel value 0xFFFFFFFFFFFFFFFF meaning
//   "no gate ever wrote here". This kernel:
//     1. Loads the accumulated u64 for each pixel.
//     2. If high half == 0xFFFFFFFF (the sentinel), writes the background
//        color; otherwise extracts the low 32 bits as the RGBA color.
//     3. Writes the result to the output framebuffer.
//
//   We test only the upper 32 bits because a real range key is always less
//   than 0xFFFFFFFF in practice, and that lets us check the sentinel with a
//   single 32-bit setp instead of a 64-bit one.
//==============================================================
.visible .entry ultra_forwardResolveKernel(
    .param .u64 fr_accum,
    .param .u32 fr_w,
    .param .u32 fr_h,
    .param .u64 fr_out,
    .param .u32 fr_bg
)
{
    .reg .pred  %p<4>;
    .reg .u32   %r<24>;
    .reg .u64   %rd<10>;

    mov.u32     %r1, %ctaid.x;
    mov.u32     %r2, %ntid.x;
    mov.u32     %r3, %tid.x;
    mad.lo.u32  %r4, %r1, %r2, %r3;

    mov.u32     %r5, %ctaid.y;
    mov.u32     %r6, %ntid.y;
    mov.u32     %r7, %tid.y;
    mad.lo.u32  %r8, %r5, %r6, %r7;

    ld.param.u32 %r9,  [fr_w];
    ld.param.u32 %r10, [fr_h];
    setp.ge.u32  %p1, %r4, %r9;
    setp.ge.u32  %p2, %r8, %r10;
    or.pred      %p1, %p1, %p2;
    @%p1 bra     L_FR_END;

    // pixel index
    mad.lo.u32   %r11, %r8, %r9, %r4;

    // load accum[idx]
    mul.wide.u32 %rd1, %r11, 8;
    ld.param.u64 %rd2, [fr_accum];
    add.s64      %rd3, %rd2, %rd1;
    ld.global.u64 %rd4, [%rd3];

    // Split rd4 -> (lo, hi). Low 32 bits = packed color, hi = range key.
    mov.b64      {%r12, %r13}, %rd4;

    // Sentinel test on hi half (range key never reaches 0xFFFFFFFF)
    setp.eq.u32  %p3, %r13, 0xFFFFFFFF;

    // Pick background or color
    ld.param.u32 %r14, [fr_bg];
    selp.b32     %r15, %r14, %r12, %p3;

    // Write to output[idx]
    mul.wide.u32 %rd5, %r11, 4;
    ld.param.u64 %rd6, [fr_out];
    add.s64      %rd7, %rd6, %rd5;
    st.global.u32 [%rd7], %r15;

L_FR_END:
    ret;
}

//==============================================================
// ultra_singleStationKernel
//
//   void singleStationKernel(GpuViewport vp, GpuStationInfo info,
//                            const float* azimuths, const uint16_t* gates,
//                            int product, float dbz_min,
//                            cudaTextureObject_t colorTex,
//                            float srv_speed, float srv_dir_rad,
//                            uint32_t* output)
//
//   Per-pixel inverse mapper for a single station -- the most common
//   interactive render path. Polar lookup, dynamic shared-mem azimuth
//   binary search, atan2 polynomial expansion, NEXRAD colormap texture
//   sample.
//
//   Provenance: cleanup of the nvcc-generated PTX for the equivalent
//   CUDA C kernel, with one hand-applied micro-opt:
//
//     #1  cosf(info.lat * pi / 180.0f) was emitted as
//             mul %f, lat, 0x40490FDB    // * pi
//             mov %f, 0x43340000          // 180.0
//             div.approx %f, %f, 180     // / 180
//             cos.approx %f, %f
//         Folded to a single multiply by the precomputed pi/180 constant
//         (0x3C8EFA35), saving the div.approx (~14 cycle latency) on every
//         pixel that touches the azimuth path.
//
//   Future rounds will: hand-tune the binary-search loop, replace the
//   shared-memory cooperative load with __ldg-style global reads on
//   modern arches with bigger L2, and inline the colormap as a constant
//   buffer instead of a texture object.
//==============================================================
.visible .entry ultra_singleStationKernel(
    .param .align 4 .b8 usk_p0[24],
    .param .align 4 .b8 usk_p1[164],
    .param .u64 usk_p2,
    .param .u64 usk_p3,
    .param .u32 usk_p4,
    .param .f32 usk_p5,
    .param .u64 usk_p6,
    .param .f32 usk_p7,
    .param .f32 usk_p8,
    .param .u64 usk_p9
)
.maxntid 256, 1, 1
.minnctapersm 4
{
    .reg .pred     %p<63>;
    .reg .b16     %rs<7>;
    .reg .f32     %f<170>;
    .reg .b32     %r<116>;
    .reg .b64     %rd<31>;


    mov.b64     %rd10, usk_p1;
    ld.param.u64     %rd14, [usk_p2];
    ld.param.u64     %rd11, [usk_p3];
    ld.param.u32     %r40, [usk_p4];
    ld.param.f32     %f32, [usk_p5];
    ld.param.u64     %rd12, [usk_p6];
    ld.param.f32     %f33, [usk_p7];
    ld.param.f32     %f34, [usk_p8];
    ld.param.u64     %rd13, [usk_p9];
    ld.param.u32     %r39, [usk_p0+20];
    ld.param.u32     %r38, [usk_p0+16];
    ld.param.f32     %f31, [usk_p0+12];
    ld.param.f32     %f30, [usk_p0+8];
    ld.param.f32     %f29, [usk_p0+4];
    ld.param.f32     %f28, [usk_p0];
    cvta.to.global.u64     %rd1, %rd14;
    mov.u32     %r41, %ntid.x;
    mov.u32     %r42, %ctaid.x;
    mov.u32     %r43, %tid.x;
    mad.lo.s32     %r1, %r42, %r41, %r43;
    mov.u32     %r2, %ntid.y;
    mov.u32     %r44, %ctaid.y;
    mov.u32     %r45, %tid.y;
    mad.lo.s32     %r3, %r44, %r2, %r45;
    setp.ge.s32     %p4, %r1, %r38;
    setp.ge.s32     %p5, %r3, %r39;
    or.pred      %p6, %p5, %p4;
    @%p6 bra     $LSSK_60;

    cvt.rn.f32.s32     %f35, %r38;
    mul.ftz.f32     %f36, %f35, 0f3F000000;
    cvt.rn.f32.s32     %f37, %r1;
    sub.ftz.f32     %f38, %f37, %f36;
    fma.rn.ftz.f32     %f1, %f30, %f38, %f29;
    cvt.rn.f32.s32     %f39, %r39;
    mul.ftz.f32     %f40, %f39, 0f3F000000;
    cvt.rn.f32.s32     %f41, %r3;
    sub.ftz.f32     %f42, %f41, %f40;
    mul.ftz.f32     %f2, %f31, %f42;
    mad.lo.s32     %r46, %r38, %r3, %r1;
    cvta.to.global.u64     %rd15, %rd13;
    mul.wide.s32     %rd16, %r46, 4;
    add.s64     %rd2, %rd15, %rd16;
    setp.eq.s64     %p7, %rd11, 0;
    @%p7 bra     $LSSK_59;

    mul.wide.s32     %rd18, %r40, 4;
    add.s64     %rd19, %rd10, %rd18;
    add.s64     %rd3, %rd19, 16;
    ld.param.f32     %f3, [%rd19+44];
    ld.param.u32     %r6, [%rd19+16];
    setp.lt.s32     %p8, %r6, 1;
    add.s64     %rd4, %rd10, 12;
    ld.param.u32     %r7, [%rd10+12];
    setp.lt.s32     %p9, %r7, 1;
    or.pred      %p10, %p8, %p9;
    ld.param.f32     %f4, [%rd19+72];
    setp.le.ftz.f32     %p11, %f4, 0f00000000;
    or.pred      %p12, %p10, %p11;
    @%p12 bra     $LSSK_58;
    bra.uni     $LSSK_3;

$LSSK_58:
    mov.u32     %r105, 1314575;
    st.global.u32     [%rd2], %r105;
    bra.uni     $LSSK_60;

$LSSK_59:
    mov.u32     %r106, 1314575;
    st.global.u32     [%rd2], %r106;
    bra.uni     $LSSK_60;

$LSSK_3:
    ld.param.f32     %f43, [%rd4+-12];
    sub.ftz.f32     %f44, %f28, %f2;
    sub.ftz.f32     %f45, %f44, %f43;
    mul.ftz.f32     %f5, %f45, 0f42DE0000;
    ld.param.f32     %f46, [%rd4+-8];
    sub.ftz.f32     %f47, %f1, %f46;
    mul.ftz.f32     %f48, %f47, 0f42DE0000;    // ULTRA-OPT #1: lat*pi/180 was emitted as mul+mov+div (3 ops).
    // Fold to a single multiply by the precomputed pi/180 constant.
    mul.ftz.f32     %f51, %f43, 0f3C8EFA35;
    cos.approx.ftz.f32     %f52, %f51;
    mul.ftz.f32     %f6, %f48, %f52;
    mul.ftz.f32     %f53, %f6, %f6;
    fma.rn.ftz.f32     %f54, %f5, %f5, %f53;
    sqrt.approx.ftz.f32     %f7, %f54;
    cvt.rn.f32.s32     %f55, %r6;
    fma.rn.ftz.f32     %f56, %f4, %f55, %f3;
    setp.lt.ftz.f32     %p13, %f7, %f3;
    setp.gt.ftz.f32     %p14, %f7, %f56;
    or.pred      %p15, %p13, %p14;
    @%p15 bra     $LSSK_57;
    bra.uni     $LSSK_4;

$LSSK_57:
    mov.u32     %r104, 1314575;
    st.global.u32     [%rd2], %r104;
    bra.uni     $LSSK_60;

$LSSK_4:
    abs.ftz.f32     %f8, %f5;
    abs.ftz.f32     %f9, %f6;
    setp.gt.ftz.f32     %p16, %f9, %f8;
    selp.f32     %f57, %f9, %f8, %p16;
    selp.f32     %f58, %f8, %f9, %p16;
    div.rn.ftz.f32     %f59, %f58, %f57;
    mul.ftz.f32     %f60, %f59, %f59;
    mov.f32     %f61, 0fBC807748;
    mov.f32     %f62, 0f3B33710B;
    fma.rn.ftz.f32     %f63, %f62, %f60, %f61;
    mov.f32     %f64, 0f3D2CDAB2;
    fma.rn.ftz.f32     %f65, %f63, %f60, %f64;
    mov.f32     %f66, 0fBD992D10;
    fma.rn.ftz.f32     %f67, %f65, %f60, %f66;
    mov.f32     %f68, 0f3DD9EA6C;
    fma.rn.ftz.f32     %f69, %f67, %f60, %f68;
    mov.f32     %f70, 0fBE117CB1;
    fma.rn.ftz.f32     %f71, %f69, %f60, %f70;
    mov.f32     %f72, 0f3E4CBCE0;
    fma.rn.ftz.f32     %f73, %f71, %f60, %f72;
    mov.f32     %f74, 0fBEAAAA7D;
    fma.rn.ftz.f32     %f75, %f73, %f60, %f74;
    mul.ftz.f32     %f76, %f60, %f75;
    fma.rn.ftz.f32     %f165, %f76, %f59, %f59;
    mov.b32     %r8, %f5;
    @%p16 bra     $LSSK_7;
    bra.uni     $LSSK_5;

$LSSK_7:
    setp.lt.s32     %p18, %r8, 0;
    @%p18 bra     $LSSK_9;

    neg.ftz.f32     %f80, %f165;
    mov.f32     %f81, 0f3FD774EB;
    mov.f32     %f82, 0f3F6EE581;
    fma.rn.ftz.f32     %f165, %f82, %f81, %f80;
    bra.uni     $LSSK_10;

$LSSK_5:
    setp.gt.s32     %p17, %r8, -1;
    @%p17 bra     $LSSK_10;

    neg.ftz.f32     %f77, %f165;
    mov.f32     %f78, 0f3FD774EB;
    mov.f32     %f79, 0f3FEEE581;
    fma.rn.ftz.f32     %f165, %f79, %f78, %f77;
    bra.uni     $LSSK_10;

$LSSK_9:
    mov.f32     %f83, 0f3FD774EB;
    mov.f32     %f84, 0f3F6EE581;
    fma.rn.ftz.f32     %f165, %f84, %f83, %f165;

$LSSK_10:
    setp.eq.ftz.f32     %p20, %f57, 0f00000000;
    setp.lt.s32     %p21, %r8, 0;
    selp.f32     %f86, 0f40490FDB, 0f00000000, %p21;
    selp.f32     %f87, 0f4016CBE4, 0f3F490FDB, %p21;
    setp.eq.ftz.f32     %p22, %f8, %f9;
    selp.f32     %f88, %f87, %f165, %p22;
    selp.f32     %f89, %f86, %f88, %p20;
    add.ftz.f32     %f90, %f8, %f9;
    abs.ftz.f32     %f91, %f90;
    setp.gtu.ftz.f32     %p23, %f91, 0f7F800000;
    copysign.f32     %f92, %f6, %f89;
    selp.f32     %f93, %f90, %f92, %p23;
    mul.ftz.f32     %f94, %f93, 0f42652EE0;
    setp.lt.ftz.f32     %p24, %f94, 0f00000000;
    add.ftz.f32     %f95, %f94, 0f43B40000;
    selp.f32     %f15, %f95, %f94, %p24;
    mad.lo.s32     %r110, %r45, %r41, %r43;
    mul.lo.s32     %r10, %r41, %r2;
    setp.ge.s32     %p25, %r110, %r7;
    @%p25 bra     $LSSK_17;

    add.s32     %r50, %r7, %r10;
    add.s32     %r51, %r110, %r10;
    not.b32     %r52, %r51;
    add.s32     %r53, %r50, %r52;
    div.u32     %r11, %r53, %r10;
    add.s32     %r54, %r11, 1;
    and.b32      %r109, %r54, 3;
    setp.eq.s32     %p26, %r109, 0;
    @%p26 bra     $LSSK_14;

    shl.b32     %r55, %r110, 2;
    mov.u32     %r56, ultra_s_az;
    add.s32     %r107, %r56, %r55;
    shl.b32     %r14, %r10, 2;
    mul.wide.s32     %rd20, %r110, 4;
    add.s64     %rd30, %rd1, %rd20;
    mul.wide.s32     %rd6, %r10, 4;

$LSSK_13:
    .pragma "nounroll";
    ld.global.nc.f32     %f96, [%rd30];
    st.shared.f32     [%r107], %f96;
    add.s32     %r110, %r110, %r10;
    add.s32     %r107, %r107, %r14;
    add.s64     %rd30, %rd30, %rd6;
    add.s32     %r109, %r109, -1;
    setp.ne.s32     %p27, %r109, 0;
    @%p27 bra     $LSSK_13;

$LSSK_14:
    setp.lt.u32     %p28, %r11, 3;
    @%p28 bra     $LSSK_17;

    mul.wide.s32     %rd9, %r10, 4;
    shl.b32     %r57, %r110, 2;
    mov.u32     %r58, ultra_s_az;
    add.s32     %r112, %r58, %r57;
    mul.lo.s32     %r60, %r2, %r41;
    shl.b32     %r23, %r60, 2;

$LSSK_16:
    mul.wide.s32     %rd21, %r110, 4;
    add.s64     %rd22, %rd1, %rd21;
    ld.global.nc.f32     %f97, [%rd22];
    st.shared.f32     [%r112], %f97;
    add.s64     %rd23, %rd22, %rd9;
    ld.global.nc.f32     %f98, [%rd23];
    add.s32     %r61, %r112, %r23;
    st.shared.f32     [%r61], %f98;
    add.s32     %r62, %r110, %r10;
    add.s32     %r63, %r62, %r10;
    add.s64     %rd24, %rd23, %rd9;
    ld.global.nc.f32     %f99, [%rd24];
    add.s32     %r64, %r61, %r23;
    st.shared.f32     [%r64], %f99;
